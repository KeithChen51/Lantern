DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/lighthouse"
# Railway preview: set DATABASE_URL to the MySQL service URL, e.g. ${{MySQL.MYSQL_URL}}
# Railway standalone server: force external binding because Railway sets HOSTNAME internally.
HOSTNAME="0.0.0.0"
OPENAI_API_KEY=""
OPENAI_BASE_URL=""
OPENAI_MODEL="qwen3.6-plus"
# chat = OpenAI-compatible Chat Completions; responses = OpenAI Responses API.
OPENAI_API_MODE="chat"
# Optional JSON object for non-standard internal gateway auth headers.
# Example: {"X-Api-Key":"TOKEN"} or {"Authorization":"Bearer TOKEN"}
OPENAI_EXTRA_HEADERS=""
# Required for Hermit RAG during both npm run build and runtime chat queries.
EMBEDDING_API_KEY=""
EMBEDDING_BASE_URL=""
EMBEDDING_MODEL=""
# Optional: use packaged src/lib/hermit/knowledge/knowledge-vectors.json during build.
# Runtime RAG still needs EMBEDDING_* to embed each user query with the same model.
HERMIT_KNOWLEDGE_USE_PREBUILT="false"
# RAG retrieval gates. Tune after real embedding/model evaluation.
HERMIT_RAG_MIN_SCORE="0.55"
HERMIT_RAG_STRONG_SCORE="0.75"
HERMIT_RAG_OUT_OF_DOMAIN_SCORE="0.80"
# Optional: fail build if database-backed Workshop/Content sources cannot be read.
HERMIT_KNOWLEDGE_REQUIRE_DATABASE="false"
